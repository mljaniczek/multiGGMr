CXX_STD = CXX14
# Suppress Armadillo diagnostic warnings from chol/inv_sympd failures.
# The MCMC engine intentionally attempts decompositions on matrices that may
# not be SPD, with graceful fallbacks (return NaN/false). Armadillo's warnings
# are noise in this context.
PKG_CPPFLAGS = -DARMA_WARN_LEVEL=0
