useDynLib(multiGGM, .registration = TRUE)
importFrom(Rcpp, evalCpp)
importFrom(stats, dgamma, rgamma, rbeta, runif, rnorm, quantile, cov)
import(parallel)

# Main fitting function
export(multiggm_mcmc)

# Simulation
export(simulate_multiggm)

# MRF normalizing constant
export(calc_mrf_logC)

# Matrix utilities
export(fix_matrix)

# Partial correlation utilities
export(precision_to_pcor)
export(posterior_pcor)
export(posterior_ci)
export(diff_prob_pcor)

# Edge selection utilities
export(pip_edges)
export(pip_diff_edge)
export(confusion_at_threshold)
export(roc_auc)

# S3 methods
S3method(print, multiggm_fit)
S3method(print, multiggm_fit_list)
S3method(summary, multiggm_fit)
S3method(print, summary.multiggm_fit)
